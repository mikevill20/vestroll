# General
NODE_ENV=development
SIMULATE_SLOW_API=false

DATABASE_URL=postgresql://user:password@localhost:5432/vestrolldb_test

# JWT / Tokens
JWT_SECRET=vestroll-secret-key
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----REPLACE_WITH_REAL_KEY-----END PUBLIC KEY-----
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----REPLACE_WITH_REAL_KEY-----END PRIVATE KEY-----
JWT_ACCESS_SECRET=test_access_secret_key_for_testing_only
JWT_REFRESH_SECRET=test_refresh_secret_key_for_testing_only
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OAuth / Third-party
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=com.example.app

# Email
EMAIL_FROM=noreply@vestroll.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=cloud_name
CLOUDINARY_API_KEY=cloudinary_api_key
CLOUDINARY_API_SECRET=cloudinary_api_secret

# AWS S3 (for direct logo uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=vestroll-assets
CDN_URL=https://d1234567890.cloudfront.net

# Two-factor / Encryption
TWO_FACTOR_ENCRYPTION_KEY=test-encryption-key-for-unit-tests-only

# Monnify
MONNIFY_API_KEY=your-monnify-api-key
MONNIFY_SECRET_KEY=your-monnify-secret-key
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_CONTRACT_CODE=your-monnify-contract-code

# Flutterwave
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com